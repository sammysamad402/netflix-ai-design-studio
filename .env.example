# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Environment Variable Template
#
# USAGE:
#   1. Copy this file:   cp .env.example .env
#
# FOR GOOGLE COLAB:
#   Use Colab Secrets instead (click the 🔑 key icon in the left sidebar).
#   Add a secret named OPENAI_API_KEY with your API key as the value.
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API Key for image generation
# Replace 'your_openai_api_key_here' with your actual key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
